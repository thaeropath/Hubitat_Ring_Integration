# Ring OAuth refresh token — obtain with: npx ring-auth-cli
RING_REFRESH_TOKEN=

# Full URL of the Hubitat Ring Integration app event endpoint.
# Shown in the app setup page after installation, e.g.:
# http://192.168.1.100/apps/api/42/ring/event
HUBITAT_EVENT_URL=

# Access token generated by the Hubitat app on first install (shown in setup page)
HUBITAT_ACCESS_TOKEN=

# Port this bridge server listens on (Hubitat drivers POST commands here)
BRIDGE_PORT=3000

# Log level: debug | info | warn | error
LOG_LEVEL=info

# Camera motion and doorbell ding delivery.
# Push (FCM) fires immediately when Ring delivers the notification.
# Polling checks Ring's event history API every 20 seconds as a fallback.
# Both are enabled by default and work together — push fires first,
# then seeds the poller so it won't re-fire the same event.
# Set either to false if you want to disable it:
#   CAMERA_PUSH=false     — disable FCM push (use if your network blocks mtalk.google.com:5228)
#   CAMERA_POLLING=false  — disable REST polling (use when push is confirmed working)
# CAMERA_PUSH=false
# CAMERA_POLLING=false

# Set to false to prevent Hubitat from being able to arm or disarm the Ring Alarm.
# When false, the alarm mode is still reported to Hubitat (view-only).
# Default: true (arm/disarm allowed)
# ALARM_CONTROL=false

# Uncomment to enable ring-client-api internal debug output
# Useful when alarm hub devices (locks, sensors, lights) are not appearing
# DEBUG=ring
