# Ring OAuth refresh token — obtain with: npx ring-auth-cli
RING_REFRESH_TOKEN=

# Hubitat hub LAN IP address
HUBITAT_IP=192.168.1.100

# Maker API app ID (visible in Hubitat → Apps → Maker API → App Info)
HUBITAT_MAKER_APP_ID=

# Maker API access token (visible in Hubitat → Apps → Maker API)
HUBITAT_ACCESS_TOKEN=

# Port this bridge server listens on (Hubitat will POST commands here)
BRIDGE_PORT=3000

# Fallback polling interval in ms if Ring WebSocket drops (default 30000)
POLL_INTERVAL_MS=30000

# Log level: debug | info | warn | error
LOG_LEVEL=info
